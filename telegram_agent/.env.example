# Telegram (user client - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=news_agent

# Channels to read (comma-separated, with or without @). Leave empty to use defaults in default_sources.py
# TELEGRAM_CHANNELS=unusual_whales,whale_alert

# RSS feeds (comma-separated URLs). Leave empty to use defaults (Reuters, Bloomberg, Fed, SEC, Treasury, CoinDesk, CryptoSlate)
# RSS_FEEDS=https://feeds.reuters.com/reuters/topNews

# X/Twitter API v2 (Bearer token from developer portal). User timelines + optional list IDs (FinTwit lists you create)
# TWITTER_BEARER_TOKEN=AAAA...
# TWITTER_USERNAMES=reutersagency,unusual_whales,business
# TWITTER_LIST_IDS=1234567890123456789
# TWITTER_MAX_TWEETS_PER_SOURCE=10

# Where to post the digest (your channel @username or chat id) — used by CLI (python -m telegram_agent.run)
TARGET_CHANNEL=@my_digest_channel

# --- Telegram Bot mode (optional): python -m telegram_agent.bot_app
# Get token from @BotFather. Add the bot to your channel as admin (can post messages).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Optional: restrict which chats may use the bot (comma-separated numeric chat ids). Empty = allow all.
# BOT_ALLOWED_CHAT_IDS=-1001234567890
# BOT_MIN_SCHEDULE_HOURS=0.25

# LLM: Gemini or Claude via OpenRouter (no OpenAI)
# Option 1: Gemini (set USE_GEMINI=true)
USE_GEMINI=true
GEMINI_API_KEY=your-gemini-key

# Option 2: Claude via OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-your-key
# Default in code is openai/gpt-4o-mini (reliable on OpenRouter). Override if needed:
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=anthropic/claude-3.5-sonnet
# Or: anthropic/claude-3-haiku (faster, cheaper)

# Inbound sources: all | rss | telegram (twitter/X only when all). CLI: --sources all|rss|telegram
# SOURCE_MODE=all

# Optional API news providers (used by ingest.py when SOURCE_MODE=api or all)
# API_USE_SYMBOL_UNIVERSE=true   # when true, FINNHUB_SYMBOLS / ALPHAVANTAGE_TICKERS / STOCKNEWSAPI_TICKERS default to your symbol universe if unset
# FINNHUB_API_KEY=...
# FINNHUB_SYMBOLS=AAPL,MSFT,NVDA
# FINNHUB_MAX_SYMBOLS_PER_RUN=0  # 0=all symbols (careful with rate limits)
# FINNHUB_SLEEP_SECONDS=0.2      # sleep between per-symbol Finnhub calls
# FINNHUB_JITTER_SECONDS=0.1
# FINNHUB_MAX_RETRIES=4
# FINNHUB_BACKOFF_SECONDS=1.2
#
# ALPHAVANTAGE_API_KEY=...
# ALPHAVANTAGE_TICKERS=AAPL,MSFT,NVDA
# ALPHAVANTAGE_TOPICS=technology,financial_markets,macroeconomy
# ALPHAVANTAGE_MAX_TICKERS_PER_REQUEST=50
# ALPHAVANTAGE_MAX_REQUESTS_PER_RUN=5
# ALPHAVANTAGE_SLEEP_SECONDS=12.5
# ALPHAVANTAGE_JITTER_SECONDS=1.5
# ALPHAVANTAGE_MAX_RETRIES=4
# ALPHAVANTAGE_BACKOFF_SECONDS=2.0
#
# STOCKNEWSAPI_TOKEN=...
# STOCKNEWSAPI_TICKERS=AAPL,MSFT,NVDA
# STOCKNEWSAPI_ITEMS=50
# STOCKNEWSAPI_PAGES=1
# STOCKNEWSAPI_MAX_TICKERS_PER_REQUEST=50
# STOCKNEWSAPI_MAX_REQUESTS_PER_RUN=10
# STOCKNEWSAPI_SLEEP_SECONDS=0.8
# STOCKNEWSAPI_JITTER_SECONDS=0.25
# STOCKNEWSAPI_MAX_RETRIES=4
# STOCKNEWSAPI_BACKOFF_SECONDS=1.0

# How many hours of news to include per run (SEC and other official feeds may publish slowly — try 24–48 if RSS looks empty)
HOURS_BACK=6
# Optional: identify your RSS client (some sites require a descriptive User-Agent)
# RSS_USER_AGENT=MyBot/1.0 (you@example.com)
# Max items after dedupe (before prompt budget trim)
MAX_ITEMS_PER_RUN=50

# Token-efficient prompts (optional)
# PROMPT_STYLE=minimal   # smallest: short system prompt + tight excerpts
# PROMPT_STYLE=balanced  # default
# PROMPT_STYLE=full      # longer excerpts per item
# MAX_SNIPPET_TELEGRAM=220
# MAX_SNIPPET_RSS=380
# MAX_PROMPT_CHARS=6500  # hard cap on user prompt size (chars)

# Micro-summarizer (cheap 1–2 sentence condensation per long item; batched JSON)
# MICRO_SUMMARIZE=true
# MICRO_PROVIDER=auto
# MICRO_BATCH_SIZE=12
# MICRO_MIN_CHARS_TELEGRAM=400
# MICRO_MIN_CHARS_RSS=280
# MICRO_MIN_CHARS_TWITTER=220
# MICRO_MAX_INPUT_CHARS=3500
# MAX_MICRO_ITEMS_PER_RUN=80
# MICRO_MODEL_GEMINI=gemini-1.5-flash
# MICRO_MODEL_OPENROUTER=anthropic/claude-3-haiku
# Consolidated digest (Market + Trend) — cost estimate uses assumed output size
# DIGEST_ASSUMED_OUTPUT_TOKENS=1800
# DIGEST_MAX_OUTPUT_TOKENS=3500
# Optional: ESTIMATE_anthropic_claude_3_5_sonnet_INPUT_PER_1M=3.0

# --- Agent (python -m telegram_agent.agent …)
# Append-only log for `orchestrate` (stderr + JSON summary). Relative paths are from repo root.
# ORCHESTRATOR_LOG_PATH=telegram_agent/data/orchestrator.log
# SQLite DB (default: telegram_agent/data/agent.sqlite). Relative paths are from repo root.
# AGENT_DB_PATH=telegram_agent/data/agent.sqlite
# SYMBOL_UNIVERSE_PATH and AGENT_DB_PATH: relative to market_analysis/ (parent of telegram_agent/).
# AGENT_BACKFILL_DAYS=365
# AGENT_MEMORY_MONTHS=6
# Structured memory prompt size (chars) + merge caps (strongest/recent trends, suggestion log window)
# AGENT_MEMORY_PROMPT_CHARS=8000
# AGENT_MEMORY_CAP_STRONGEST=20
# AGENT_MEMORY_CAP_RECENT=20
# AGENT_MEMORY_SUGGESTION_DAYS=30
# AGENT_MAX_TELEGRAM_BACKFILL=3000
# AGENT_RESEARCH_MODEL=anthropic/claude-sonnet-4.5
# Minimum confidence (0..1) to persist a research opportunity (novel vs memory + high bar)
# AGENT_RESEARCH_MIN_CONFIDENCE=0.75
# Max number of news rows fetched AND included in the research prompt (live + backfill + dry-run).
# MAX_NUM_OFNEWS=200
# Research LLM: max completion budget + dry-run typical output size (cost estimate)
# AGENT_RESEARCH_MAX_OUTPUT_TOKENS=12000
# AGENT_RESEARCH_ASSUMED_OUTPUT_TOKENS=4000
# Max recommendation rows with meta_json.tester shown in the research prompt (newest first)
# AGENT_RESEARCH_TESTER_PROMPT_LIMIT=50
#
# Strategy test agent (test-suggestions): aggregate metrics + optimization scalar for research feedback
# Comma-separated: sharpe, alpha, max_drawdown, oos_sharpe, calmar, significance
# TEST_METRICS_ENABLED=sharpe,alpha,max_drawdown,oos_sharpe,calmar,significance
# Single metric whose scalar is stored as optimization_value (higher = better; max_drawdown negated; significance uses 1-p)
# TEST_OPTIMIZATION_METRIC=sharpe
# TEST_BENCHMARK_SYMBOL=SPY
# TEST_RISK_FREE_ANNUAL=0.04
# TEST_OOS_SPLIT=0.5
# Publish thinking + suggestions + memory to TARGET_CHANNEL after each research run
# AGENT_RESEARCH_PUBLISH=true
# Daily research backfill: python -m telegram_agent.agent research --backfill-from YYYY-MM-DD --backfill-to YYYY-MM-DD
# Publish each simulated day (in addition to AGENT_RESEARCH_PUBLISH) — set false to backfill quietly
# AGENT_RESEARCH_BACKFILL_PUBLISH=true
# Seconds to sleep between days (rate limit / API courtesy)
# AGENT_RESEARCH_BACKFILL_SLEEP_SECONDS=1

# Competitive systematic bots (python -m telegram_agent.agent competitive-bots)
# Universe = priority <= COMPETITIVE_BOTS_MAX_PRIORITY (default 1 = P0 and P1 only)
# COMPETITIVE_BOTS_MAX_PRIORITY=1
# COMPETITIVE_BOTS_MAX_PICKS=3
# COMPETITIVE_BOTS_MIN_BARS=25
# COMPETITIVE_BOTS_REVIEW_HORIZON_DAYS=12
# COMPETITIVE_BOTS_ENTRY_SPAN_DAYS=3
# COMPETITIVE_BOTS_PUBLISH=true
# Walk-forward backtest: max symbols per interval, eval grid size, optional JSON horizons
# COMPETITIVE_BACKTEST_MAX_SYMBOLS=50
# COMPETITIVE_BACKTEST_MAX_EVAL_POINTS=2000
# COMPETITIVE_BACKTEST_MAX_TOTAL_ROWS=3000000
# COMPETITIVE_BACKTEST_HORIZON_OVERRIDES={"1d":7}
# Comma list: restrict walk-forward backtest to these symbols (use with: competitive-bots --backtest --backtest-symbols env)
# COMPETITIVE_BACKTEST_SYMBOLS=AAPL,MSFT
# Optional default mode: universe | env | p0-full-coverage
# COMPETITIVE_BACKTEST_SYMBOL_MODE=universe
# Thresholds for p0-full-coverage mode (priority-0 symbols must meet all three)
# FULL_COVERAGE_MIN_BARS_1D=200
# FULL_COVERAGE_MIN_BARS_1H=400
# FULL_COVERAGE_MIN_BARS_1M=800
# Per-symbol forward-return stats for each of the 3 bots (large JSON): competitive-bots --backtest --backtest-per-ticker
# COMPETITIVE_BACKTEST_PER_TICKER=false

# Prices (yfinance) batching knobs
# PRICES_YF_BATCH_SIZE=80
# PRICES_YF_SLEEP_SECONDS=0.5
# Intraday: `python -m telegram_agent.agent prices --intervals 1h,1m` stores in prices_hourly / prices_minute
# PRICES_INTRADAY_1H_MAX_BACKFILL_DAYS=730
# PRICES_INTRADAY_1M_MAX_BACKFILL_DAYS=30
# PRICES_INTRADAY_CHUNK_DAYS_1H=120
# PRICES_INTRADAY_CHUNK_DAYS_1M=7
# PRICES_INTRADAY_PREPOST=true
# PRICES_INTRADAY_AUTO_ADJUST=true
# PRICES_INTRADAY_1H_INCREMENTAL_LOOKBACK_DAYS=14
# PRICES_INTRADAY_1M_INCREMENTAL_LOOKBACK_DAYS=7
# Extract: batched LLM ticker extraction (needs OPENROUTER_API_KEY or GEMINI_API_KEY)
# EXTRACT_USE_LLM=true
# EXTRACT_LLM_MODEL=anthropic/claude-3-haiku
# EXTRACT_LLM_BATCH_SIZE=12
# EXTRACT_MAX_CHARS_PER_ITEM=2200
# EXTRACT_REGEX_FALLBACK=true
#
# Universe preprocessor: cheap LLM tags each news row with allowlist tickers (symbol_news_linkage).
# `python -m telegram_agent.agent universe-preprocess` or automatic run before research when enabled.
# NEWS_UNIVERSE_PREPROCESS_MODEL=anthropic/claude-3-haiku
# NEWS_UNIVERSE_PREPROCESS_BATCH_SIZE=16
# NEWS_UNIVERSE_PREPROCESS_MAX_ROWS=100000
# Research prompt: only include news linked to the universe (set false for legacy “all news in window”)
# AGENT_RESEARCH_UNIVERSE_NEWS_LINKAGE=true
# Run preprocessor automatically at the start of each research run
# AGENT_RESEARCH_RUN_UNIVERSE_PREPROCESS=true

# --- Fixed symbol universe mode (top-1000 traded tickers) ---
# Enables universe-constrained regex extraction + universe-only price fetching.
# If SYMBOL_UNIVERSE_PATH or SYMBOL_UNIVERSE_ENV is set, universe mode turns on automatically
# unless you set SYMBOL_UNIVERSE_ENABLED=false.
# Provide the universe either as:
#   - SYMBOL_UNIVERSE_ENV: comma-separated symbols
#   - SYMBOL_UNIVERSE_PATH: JSON file: ["AAPL", ...], {"symbols":[...]}, or [{"ticker":"AAPL",...}, ...]
# SYMBOL_UNIVERSE_ENABLED=false
# SYMBOL_UNIVERSE_ENV=AAPL,SPY,BTC-USD
# SYMBOL_UNIVERSE_PATH=telegram_agent/data/symbol_universe_top1000.json

# When enabled, memory inputs can be limited to news items that already have
# extracted mentions in the fixed universe.
# MEMORY_USE_UNIVERSE_NEWS_ONLY=true

# --- Alpaca (RSI live paper trading: python -m telegram_agent.rsi_alpaca_live)
# Dashboard: https://app.alpaca.markets/ — create API keys; paper and live use the same key pair
# (the host switches with ALPACA_PAPER / paper-api vs api).
# APCA_API_KEY_ID=PK...
# APCA_API_SECRET_KEY=...
# ALPACA_PAPER=true
# Intraday bars: iex (default, free) or sip (paid subscription).
# ALPACA_DATA_FEED=iex
# Optional path for tracked lots (time exits; Alpaca merges positions per symbol).
# RSI_ALPACA_STATE_PATH=telegram_agent/data/rsi_alpaca_state.json


