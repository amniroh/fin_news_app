# Copy to repo root as `.env` and fill in secrets. Paths below are relative to the
# `market_analysis/` repo root (parent of `telegram_agent/`).

OPENROUTER_API_KEY=

# Optional: default DB location is telegram_agent/data/agent.sqlite
# AGENT_DB_PATH=telegram_agent/data/agent.sqlite

SYMBOL_UNIVERSE_PATH=telegram_agent/top1000_investments.json

# Orchestrator append log (relative to repo root)
ORCHESTRATOR_LOG_PATH=telegram_agent/data/orchestrator.log

# Headless server: avoid posting to Telegram from research unless you want it
AGENT_RESEARCH_PUBLISH=false
AGENT_RESEARCH_BACKFILL_PUBLISH=false

# Add your other keys (TELEGRAM_*, FINNHUB_*, etc.) from your laptop `.env`.
