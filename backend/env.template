# LLM Provider Configuration
# Choose one: Gemini (recommended, free tier available) or OpenRouter

# Option 1: Use Gemini API (Recommended - Free tier available)
# Get your API key from: https://makersuite.google.com/app/apikey
# Set USE_GEMINI=true to prioritize Gemini over OpenRouter
USE_GEMINI=true
GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: Use OpenRouter API (Alternative)
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Database Mode (optional)
# Set to "true" for sandbox mode (no AWS needed)
# Set to "false" for DynamoDB mode (requires AWS setup)
USE_SANDBOX=true

# AWS Credentials (only needed if USE_SANDBOX=false)
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_REGION=eu-central-1

